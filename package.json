{
  "name": "genui",
  "private": true,
  "description": "A type-safe bridge between LLM outputs and your React components",
  "author": "Mohammad Ashrafian (https://github.com/mohammadashrafian)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mohammadashrafian/genuikit.git"
  },
  "homepage": "https://github.com/mohammadashrafian/genuikit#readme",
  "bugs": {
    "url": "https://github.com/mohammadashrafian/genuikit/issues"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "clean": "turbo clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^20.11.0",
    "eslint": "^9.0.0",
    "prettier": "^3.2.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  }
}
