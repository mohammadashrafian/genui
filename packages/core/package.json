{
  "name": "@genuikit/core",
  "version": "0.5.3",
  "description": "Type-safe component registry, streaming, bidirectional sync, and security for LLM-driven UI",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/client.d.ts",
        "default": "./dist/client.js"
      },
      "require": {
        "types": "./dist/client.d.cts",
        "default": "./dist/client.cjs"
      }
    },
    "./stream": {
      "import": {
        "types": "./dist/stream.d.ts",
        "default": "./dist/stream.js"
      },
      "require": {
        "types": "./dist/stream.d.cts",
        "default": "./dist/stream.cjs"
      }
    },
    "./wire-format": {
      "import": {
        "types": "./dist/wire-format.d.ts",
        "default": "./dist/wire-format.js"
      },
      "require": {
        "types": "./dist/wire-format.d.cts",
        "default": "./dist/wire-format.cjs"
      }
    },
    "./action": {
      "import": {
        "types": "./dist/action.d.ts",
        "default": "./dist/action.js"
      },
      "require": {
        "types": "./dist/action.d.cts",
        "default": "./dist/action.cjs"
      }
    },
    "./security": {
      "import": {
        "types": "./dist/security.d.ts",
        "default": "./dist/security.js"
      },
      "require": {
        "types": "./dist/security.d.cts",
        "default": "./dist/security.cjs"
      }
    }
  },
  "typesVersions": {
    "*": {
      "client": [
        "dist/client.d.ts"
      ],
      "stream": [
        "dist/stream.d.ts"
      ],
      "wire-format": [
        "dist/wire-format.d.ts"
      ],
      "action": [
        "dist/action.d.ts"
      ],
      "security": [
        "dist/security.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "genui",
    "llm",
    "ui",
    "schema",
    "validation",
    "zod",
    "component-registry"
  ],
  "license": "MIT",
  "author": "Mohammad Ashrafian (https://github.com/mohammadashrafian)",
  "repository": {
    "type": "git",
    "url": "https://github.com/mohammadashrafian/genuikit.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/mohammadashrafian/genuikit#readme",
  "bugs": {
    "url": "https://github.com/mohammadashrafian/genuikit/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
