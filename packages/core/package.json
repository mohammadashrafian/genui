{
  "name": "@genui/core",
  "version": "0.2.0",
  "description": "Type-safe component registry and schema validation for LLM-driven UI",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "keywords": ["genui", "llm", "ui", "schema", "validation", "zod", "component-registry"],
  "license": "MIT",
  "author": "Mohammad Ashrafian (https://github.com/mohammadashrafian)",
  "repository": {
    "type": "git",
    "url": "https://github.com/mohammadashrafian/genui.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/mohammadashrafian/genui#readme"
}
