{
  "name": "@genuikit/cli",
  "version": "0.5.0",
  "description": "CLI tool for initializing GenUI component registries",
  "type": "module",
  "bin": {
    "genui": "./dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/prompts": "^2.4.9",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "genui",
    "cli",
    "init",
    "scaffold",
    "component-registry"
  ],
  "license": "MIT",
  "author": "Mohammad Ashrafian (https://github.com/mohammadashrafian)",
  "repository": {
    "type": "git",
    "url": "https://github.com/mohammadashrafian/genuikit.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/mohammadashrafian/genuikit#readme",
  "bugs": {
    "url": "https://github.com/mohammadashrafian/genuikit/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
