{
  "name": "@genui/react",
  "version": "0.2.0",
  "description": "React hooks for rendering LLM-driven generative UI components",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@genui/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "zod": "^3.23.0",
    "jsdom": "^25.0.0"
  },
  "keywords": ["genui", "react", "llm", "hooks", "generative-ui"],
  "license": "MIT",
  "author": "Mohammad Ashrafian (https://github.com/mohammadashrafian)",
  "repository": {
    "type": "git",
    "url": "https://github.com/mohammadashrafian/genui.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/mohammadashrafian/genui#readme"
}
