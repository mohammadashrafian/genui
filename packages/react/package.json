{
  "name": "@genuikit/react",
  "version": "0.5.3",
  "description": "React hooks for rendering LLM-driven generative UI components",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/client.d.ts",
        "default": "./dist/client.js"
      },
      "require": {
        "types": "./dist/client.d.cts",
        "default": "./dist/client.cjs"
      }
    },
    "./render": {
      "import": {
        "types": "./dist/render.d.ts",
        "default": "./dist/render.js"
      },
      "require": {
        "types": "./dist/render.d.cts",
        "default": "./dist/render.cjs"
      }
    },
    "./streaming": {
      "import": {
        "types": "./dist/streaming.d.ts",
        "default": "./dist/streaming.js"
      },
      "require": {
        "types": "./dist/streaming.d.cts",
        "default": "./dist/streaming.cjs"
      }
    },
    "./co-agent": {
      "import": {
        "types": "./dist/co-agent.d.ts",
        "default": "./dist/co-agent.js"
      },
      "require": {
        "types": "./dist/co-agent.d.cts",
        "default": "./dist/co-agent.cjs"
      }
    },
    "./dev": {
      "import": {
        "types": "./dist/dev.d.ts",
        "default": "./dist/dev.js"
      },
      "require": {
        "types": "./dist/dev.d.cts",
        "default": "./dist/dev.cjs"
      }
    }
  },
  "typesVersions": {
    "*": {
      "client": [
        "dist/client.d.ts"
      ],
      "render": [
        "dist/render.d.ts"
      ],
      "streaming": [
        "dist/streaming.d.ts"
      ],
      "co-agent": [
        "dist/co-agent.d.ts"
      ],
      "dev": [
        "dist/dev.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@genuikit/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "zod": "^3.23.0",
    "jsdom": "^25.0.0"
  },
  "keywords": [
    "genui",
    "react",
    "llm",
    "hooks",
    "generative-ui"
  ],
  "license": "MIT",
  "author": "Mohammad Ashrafian (https://github.com/mohammadashrafian)",
  "repository": {
    "type": "git",
    "url": "https://github.com/mohammadashrafian/genuikit.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/mohammadashrafian/genuikit#readme",
  "bugs": {
    "url": "https://github.com/mohammadashrafian/genuikit/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
